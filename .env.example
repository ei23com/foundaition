# ─── Server ────────────────────────────────────────────────
LISTEN_PORT=8080
DB_FILE=./foundaition.db
UI_LANGUAGE=de

# ─── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=http://10.1.1.11:4000/v1
OPENAI_MODELS="summarizer, image_model, fast_coder"
OPENAI_MODEL=summarizer
SUMMARY_MAX_TOKENS=64000
AUTO_SUMMARIZE=true

# ─── Whisper ──────────────────────────────────────────────
WHISPER_URL=http://localhost:8081
WHISPER_MODEL=whisper
WHISPER_API_KEY=sk-...

# ─── Crawling ─────────────────────────────────────────────
CRAWL_TIMEOUT=60
CRAWL_MAX_CHARS=64000

# ─── YouTube / yt-dlp ─────────────────────────────────────
YTDLP_PATH=./yt-dlp_linux
YOUTUBE_SUBTITLE_METHOD=auto

# ─── RSS Feed ─────────────────────────────────────────────
RSS_BASE_URL=
RSS_ITEM_COUNT=30
RSS_EXTRA_ACTION_LINK=

# ─── Processing ───────────────────────────────────────────
MAX_PROCESS_DAYS=14
CATEGORIZE_MODEL=fast_coder